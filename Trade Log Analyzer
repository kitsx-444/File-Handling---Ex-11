with open('sentiment_log.txt', 'r') as lines:
	text = lines.readlines() # To get multiple lines use readlines instead of read.

def code_block():
	count_buy = 0
	count_neutral = 0
	count_sell = 0
	pairs = []

	for line in text:
		parts = line.split('|')
		pairs.append(parts[0].strip())
		if 'Bullish' in parts[1]:
			count_buy += 1
		if 'Bearish' in parts[1]:
			count_sell += 1
		if 'Neutral' in parts[1]:
			count_neutral += 1

	return count_buy, count_sell, count_neutral, pairs

count_buy, count_sell, count_neutral, pairs = code_block()

def display_summary(count_buy, count_neutral, count_sell, pairs):
	print('--- Trade Log Summary ---')
	print('Total Entries:', len(text)) # len(text). Since text is a list of lines, len() gives you the count.
	print('\nBullish:', count_buy)
	print('Neutral:', count_neutral)
	print('Bearish:', count_sell, '\n')
	print(pairs)

	if count_buy > count_sell and count_neutral:
		print('Most common sentiment: Bullish')
	elif count_sell > count_buy and count_neutral:
		print('Most common sentiment: Bearish')
	elif count_neutral > count_buy and count_sell:
		print('Most common sentiment: Neutral')

display_summary(count_buy, count_neutral, count_sell, pairs)

