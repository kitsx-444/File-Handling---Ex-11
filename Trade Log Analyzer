# Count works now

with open('sentiment_log.txt', 'r') as lines:
	text = lines.readlines() # To get multiple lines use readlines instead of read.

def code_block():
	count_buy = 0
	count_neutral = 0
	count_sell = 0

	for line in text:
		parts = line.split('|')
		if 'Bullish' in parts[1]:
			count_buy += 1
		if 'Bearish' in parts[1]:
			count_sell += 1
		if 'Neutral' in parts[1]:
			count_neutral += 1
	return count_buy, count_sell, count_neutral # You return multiple variables with a comma

count_buy, count_sell, count_neutral = code_block() 
# You can create a variable using the comma to store multiple return variables.
That's called tuple unpacking; when a function returns multiple values, you can catch them all in one line.

def display_summary(count_buy, count_neutral, count_sell):
	print('--- Trade Log Summary ---')
	print('Total Entries:', len(text)) # len(text). Since text is a list of lines, len() gives you the count.
	print('\nBullish:', count_buy)
	print('Neutral:', count_neutral)
	print('Bearish:', count_sell, '\n')

display_summary(count_buy, count_neutral, count_sell)
